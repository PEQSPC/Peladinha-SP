{
  "name": "peladinha-sp-backend",
  "version": "1.0.0",
  "description": "peladinha-sp backend description",
  "main": "index.js",
  "repository": "https://github.com/PEQSPC/Peladinha-SP",
  "author": "peqspc",
  "license": "MIT",
  "scripts": {
    "dev": "nodemon --exec tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "docker:build": "docker build -t peladinha-sp-backend .",
    "docker:run": "docker run -p 3000:3000 peladinha-sp-backend",
    "docker:run:prod": "docker run -d -p 3000:3000 --name peladinha-sp peladinha-sp-backend"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.3",
    "@types/supertest": "^7.2.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/src/**/*.test.ts"
    ]
  },
  "dependencies": {
    "express": "^5.2.1"
  }
}
